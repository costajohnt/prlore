{
  "name": "prlore",
  "version": "0.1.0",
  "description": "Mine a repo's PR-review history and current code into a portable AGENTS.md conventions file",
  "license": "MIT",
  "type": "module",
  "bin": {
    "prlore": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/graphql": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "msw": "^2.14.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/costajohnt/prlore.git"
  },
  "bugs": {
    "url": "https://github.com/costajohnt/prlore/issues"
  },
  "homepage": "https://github.com/costajohnt/prlore#readme"
}
